    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Get HTML from current item\nconst html = item.json.data;\n\n// Use regex to extract the CF path\nconst match = html.match(/\\/content\\/dam\\/wknd\\/en\\/content-fragments\\/articles\\/[a-zA-Z0-9\\-]+/);\n\nif (!match) {\n  throw new Error(\"CF path not found in HTML response\");\n}\n\n\nconst cfPath = match[0]\n\nreturn {\n  json: {\n    cfPath: cfPath // e.g., /content/dam/wknd/en/content-fragments/finding-freedom-in-the-mountain-1773875324049\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2368,
        -240
      ],
      "id": "b6867f24-8545-4e9b-89d6-3ea6787dce5a",
      "name": "Get CF name"
    },
    {
      "parameters": {
        "jsCode": "// Get all items from Merge node\nconst items = $input.all();\n\n// Separate AI items (have output[]) and article items (have title)\nconst aiItems = items.filter(i => i.json.output);\nconst articleItems = items.filter(i => i.json.title);\n\n// Build one result per article/AI pair\nconst results = [];\n\nfor (let idx = 0; idx < articleItems.length; idx++) {\n  const articleItem = articleItems[idx];\n  const aiItem = aiItems[idx];\n\n  // Extract AI raw text\n  const raw = aiItem.json.output[0].content[0].text;\n\n  // Clean markdown fences\n  const cleaned = raw\n    .replace(/```json/g, \"\")\n    .replace(/```/g, \"\")\n    .trim();\n\n  // Parse AI JSON\n  let seo;\n  try {\n    seo = JSON.parse(cleaned);\n  } catch (e) {\n    throw new Error(`Failed to parse AI JSON for item ${idx}: ${e.message}`);\n  }\n\n  // Combine into one object per file\n  results.push({\n    json: {\n      title: articleItem.json.title,\n      author: articleItem.json.author,\n      date: articleItem.json.date,\n      body: articleItem.json.body,\n      thumbnail_url: articleItem.json.thumbnail_url,\n      figmaKey: articleItem.json.key,\n      seoTitle: seo.seoTitle,\n      metaDescription: seo.metaDescription,\n      slug: seo.slug,\n      keywords: Array.isArray(seo.keywords) ? seo.keywords.join(',') : seo.keywords,\n      category: seo.category,\n      ogTitle: seo.ogTitle,\n      ogDescription: seo.ogDescription,\n      imageRef: articleItem.json.imageRef,\n      imageNodeId: articleItem.json.imageNodeId\n    }\n  });\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
