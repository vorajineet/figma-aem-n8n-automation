    {
      "parameters": {
        "jsCode": "// Get node-scoped static data\nconst staticData = $getWorkflowStaticData('node');\nstaticData.processedFiles = staticData.processedFiles || [];\n\n// Filter new files\nconst allFiles = $input.all().flatMap(item => item.json.files);\n\nconst newReadyFiles = allFiles.filter(f => {\n    return f.name.includes('[Ready]') && !staticData.processedFiles.includes(f.key);\n});\n\n// Save processed file keys\nstaticData.processedFiles.push(...newReadyFiles.map(f => f.key));\n\n// Return only new ready files\nreturn newReadyFiles.map(f => ({ json: f }));"
      },
