    {
      "parameters": {
        "jsCode": "// Loop over input items and extract article fields\nconst results = [];\n\nfor (const item of $input.all()) {\n\n  const root = item.json.document;\n\n  let title = \"\";\n  let author = \"\";\n  let date = \"\";\n  let bodyParts = [];\n  let imageNodeId = \"\";\n  let imageRef = \"\";\n\n  function walk(node) {\n\n    // Extract IMAGE node ID from background\n    if (!imageNodeId && node.fills && node.fills.length > 0) {\n  const imgFill = node.fills.find(f => f.type === 'IMAGE');\n  if (imgFill) {\n    imageRef = imgFill.imageRef;\n    imageNodeId = node.id; // ← capture the node ID (e.g. \"6:8\")\n  }\n}\n\n    if (node.type === \"TEXT\" && node.characters) {\n\n      const text = node.characters.trim();\n\n      // Title\n      if (!title && node.style?.fontSize === 48) {\n        title = text;\n      }\n\n      // Author\n      else if (text.startsWith(\"By \")) {\n        author = text.replace(\"By \", \"\");\n      }\n\n      // Date\n      else if (/\\w+ \\d{1,2}, \\d{4}/.test(text)) {\n        date = text;\n      }\n\n      // Body paragraphs\n      else if (node.style?.fontSize === 16) {\n        bodyParts.push(text);\n      }\n    }\n\n    if (node.children) {\n      node.children.forEach(walk);\n    }\n  }\n\n  walk(root);\n\n  item.json.article = {\n    title,\n    author,\n    date,\n    body: bodyParts.join(\"\\n\\n\"),\n    imageRef,\n    imageNodeId\n  };\n\n  results.push(item);\n}\n\nreturn results.map(item => item.json.article);"
      },
