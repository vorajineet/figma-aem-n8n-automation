            {
              "content": "=Given this article:\nTitle: {{$json.title}}\nBody: {{$json.body}}\n\nReturn JSON with:\n- seoTitle (max 60 chars)\n- metaDescription (max 160 chars)\n- slug\n- keywords (array of 5 keywords)\n- category (one word)\n- ogTitle\n- ogDescription\n- ogType (article)\n\nOnly return valid JSON"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
